# ---------- Neon Postgres ----------
# Use the pooled connection string (ending in -pooler) for serverless runtimes.
# bodyflow keeps tables in a dedicated Postgres schema named `bodyflow`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/neondb?sslmode=require"

# ---------- Clerk Auth ----------
# bodyflow Clerk app: app_3F1YgZupaC522xCiwUnzuAqMFsn
# Pull keys: clerk auth login && clerk link --app app_3F1YgZupaC522xCiwUnzuAqMFsn && clerk env pull
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# ---------- Seed (one-time historical import) ----------
# SEED_USER_ID="user_xxx"
# npm run db:seed-measurements

# ---------- App ----------
NEXT_PUBLIC_APP_URL="http://localhost:3010"
# If dev server picks another port, match it here and in Clerk → Domains.
# ngrok mobile testing: npm run ngrok (updates this file), then add the ngrok URL in Clerk → Domains
# ALLOWED_DEV_ORIGINS="localhost,xxxx.ngrok-free.dev"

# ---------- Matvaretabellen (one-time seed) ----------
# npm run db:seed-matvaretabellen

# ---------- Custom foods (photo / OCR / AI) ----------
# Prefix for user-scanned products stored in food_products (e.g. go4g-uuid)
FOOD_CUSTOM_PREFIX_ID="go4g"
# Optional: OpenAI vision for label extraction (falls back to browser OCR)
# OPENAI_API_KEY="sk-..."
# OPENAI_VISION_MODEL="gpt-4o-mini"

# ---------- Kassal.app API ----------
# Product search + EAN barcode lookup for meal logging
# Docs: https://kassal.app/docs/api.json
KASSAL_API_KEY=""

# ---------- Withings API (Public API — OAuth 2.0) ----------
# Create an app at https://developer.withings.com/dashboard/
# API reference: https://developer.withings.com/llms.md
WITHINGS_CLIENT_ID=""
WITHINGS_CLIENT_SECRET=""
WITHINGS_REDIRECT_URI="http://localhost:3010/api/integrations/withings/callback"
# Required when Withings is enabled — encrypts access/refresh tokens at rest (AES-256-GCM).
# Generate: openssl rand -base64 32
# Or hex:   openssl rand -hex 32
WITHINGS_TOKEN_ENCRYPTION_KEY=""
# Optional: set to "demo" in authorize URL for testing without a device
# WITHINGS_OAUTH_MODE=demo
# Required in production — signs OAuth state (openssl rand -base64 32)
# WITHINGS_STATE_SECRET=""
# Required for public prod webhook URL — path token Withings calls (openssl rand -base64 32)
# WITHINGS_WEBHOOK_SECRET=""
