# ---------- Neon Postgres ----------
# Use the pooled connection string (ending in -pooler) for serverless runtimes.
# bodyflow keeps tables in a dedicated Postgres schema named `bodyflow`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/neondb?sslmode=require"

# ---------- Clerk Auth ----------
# bodyflow Clerk app: app_3F1YgZupaC522xCiwUnzuAqMFsn
# Pull keys: clerk auth login && clerk link --app app_3F1YgZupaC522xCiwUnzuAqMFsn && clerk env pull
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# ---------- App ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------- Withings API (Public API — OAuth 2.0) ----------
# Create an app at https://developer.withings.com/dashboard/
# API reference: https://developer.withings.com/llms.md
WITHINGS_CLIENT_ID=""
WITHINGS_CLIENT_SECRET=""
WITHINGS_REDIRECT_URI="http://localhost:3000/api/integrations/withings/callback"
# Optional: set to "demo" in authorize URL for testing without a device
# WITHINGS_OAUTH_MODE=demo
# Optional: separate secret for OAuth state signing (defaults to CLERK_SECRET_KEY)
# WITHINGS_STATE_SECRET=""
