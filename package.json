{
  "name": "bodyflow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3010",
    "dev:fresh": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-port.ps1 -Port 3010 && next dev -p 3010",
    "ngrok": "powershell -ExecutionPolicy Bypass -File ./scripts/ngrok-mobile.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed-measurements": "tsx db/seed-measurements.ts",
    "db:seed-matvaretabellen": "tsx db/seed-matvaretabellen.ts",
    "import:exercises": "tsx scripts/import-exercises.ts",
    "withings:encrypt-tokens": "tsx scripts/encrypt-withings-tokens.ts",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "translate:exercises": "tsx scripts/translate-exercises.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@clerk/nextjs": "^7.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@zxing/browser": "^0.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.511.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^7.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
